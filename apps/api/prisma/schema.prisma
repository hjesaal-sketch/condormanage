generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String    @id @default(cuid())
  name         String
  subdomain    String    @unique
  config       Json?
  status       TenantStatus @default(ACTIVE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  users        User[]
  units        Unit[]
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  password     String    // Hashed
  role         Role      @default(RESIDENT)
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  units        UnitUserRel[]
}

enum Role {
  ADMIN
  RESIDENT
  GUEST
}

model Unit {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  number       String
  floor        Int?
  area         Float?
  type         UnitType  @default(APARTMENT)
  status       UnitStatus @default(AVAILABLE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  users        UnitUserRel[]
  invoices     Invoice[]
}

enum UnitType {
  APARTMENT
  PENTHOUSE
  COMMERCIAL
  PARKING
}

enum UnitStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

model UnitUserRel {
  id           String    @id @default(cuid())
  unitId       String
  unit         Unit      @relation(fields: [unitId], references: [id])
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  relationship Relationship @default(OWNER)
  startDate    DateTime
  endDate      DateTime?
}

enum Relationship {
  OWNER
  TENANT
  RESIDENT
}

model Invoice {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  unitId       String
  unit         Unit      @relation(fields: [unitId], references: [id])
  number       String    @unique
  issueDate    DateTime
  dueDate      DateTime
  amount       Decimal   @db.Decimal(10,2)
  concept      String
  status       InvoiceStatus @default(PENDING)
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  payments     Payment[]
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Payment {
  id           String    @id @default(cuid())
  invoiceId    String
  invoice      Invoice   @relation(fields: [invoiceId], references: [id])
  amount       Decimal   @db.Decimal(10,2)
  date         DateTime
  method       PaymentMethod
  reference    String?
  status       PaymentStatus @default(COMPLETED)
  createdAt    DateTime  @default(now())
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_PAYMENT
  CREDIT_CARD
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model AuditLog {
  id           String    @id @default(cuid())
  userId       String
  tenantId     String
  action       String
  module       String
  entityId     String?
  changes      Json?
  ip           String?
  userAgent    String?
  createdAt    DateTime  @default(now())
}

model Setting {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  key          String
  value        Json
  group        String?   // billing, maintenance, etc
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([tenantId, key])
}